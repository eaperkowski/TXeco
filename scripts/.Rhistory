labs(x = "Treatment", y = expression(bold("Leaf "*delta^"15"*"N  (‰)"))) +
theme_classic(base_size = 18) +
theme(axis.title = element_text(face = "bold"))
ggarrange(theory_plot, actual_plot, align = "hv")
theory_plot <- ggplot(data = df_theoretical,
aes(x = treatment, y = leaf_d15n)) +
geom_boxplot() +
scale_y_continuous(limits = c(0, 150)) +
scale_x_discrete(labels = c(expression(""^"14"*"N non-myc."),
expression(""^"14"*"N myc."),
expression(""^"15"*"N non-myc."),
expression(""^"15"*"N myc."))) +
labs(x = "Treatment", y = expression(bold("Expected Leaf "*delta^"15"*"N"))) +
theme_classic(base_size = 18) +
theme(axis.text.y = element_blank(),
axis.ticks.y = element_blank(),
axis.title = element_text(face = "bold"))
png("../../../Desktop/ava_poster_final.png", width = 16, height = 5,
units = "in", res = 600)
ggarrange(theory_plot, actual_plot, align = "hv")
dev.off()
png("../../../Desktop/ava_poster_final.png", width = 12, height = 5,
units = "in", res = 600)
ggarrange(theory_plot, actual_plot, align = "hv")
dev.off()
